# ──────────────────────────────────────────────────────────────
# QAN Throne — környezeti változók
# Másold át: copy .env.example .env  (Windows)
#            cp .env.example .env    (Linux/Mac)
# ──────────────────────────────────────────────────────────────

# QAN TestNet RPC
QAN_RPC_URL=https://rpc-testnet.qanplatform.com
QAN_CHAIN_ID=1121
QAN_EXPLORER=https://testnet.qanscan.com

# Deploy-hoz szükséges privát kulcs (64 hex karakter, 0x NÉLKÜL)
# Szerezz teszt QANX-et: https://faucet.qanplatform.com
ADMIN_PRIVATE_KEY=

# A deploy után automatikusan kitöltődik:
THRONE_CONTRACT_ADDRESS=

# Express szerver port (Railway beállítja automatikusan)
PORT=3000
