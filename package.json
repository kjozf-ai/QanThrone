    "autoprefixer": "^10.4.20",
    "dotenv":    "^16.4.7",
    "hardhat":   "^2.22.17",
    "postcss":   "^8.4.49",
    "react":     "^18.3.1",
    "react-dom": "^18.3.1",
    "tailwindcss":"^3.4.17",
